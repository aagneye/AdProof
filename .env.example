# =========================
# Local demo (meeting-ready)
# =========================
# Uses SQLite + local storage + dummy pipeline outputs
DATABASE_URL=sqlite:///./apps/worker/adproof_local.db

# Redis / Job Queue (optional — API uses BackgroundTasks by default)
REDIS_URL=redis://localhost:6379/0
USE_RQ_WORKER=false

# Backblaze B2 (leave empty for local demo storage)
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=adproof-assets
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# Demo mode — runs simulated pipeline without AI API keys
PIPELINE_MODE=mock
ADPROOF_DEMO_MODE=true
DEMO_MODE=true
LOCAL_STORAGE_PATH=./apps/worker/local_storage
API_BASE_URL=http://localhost:8000

# AI Providers (required when DEMO_MODE=false)
GMICLOUD_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
STABILITY_API_KEY=
RUNWAY_API_KEY=
LUMA_API_KEY=

# App Config
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
B2_WEBHOOK_URL=http://localhost:3000/api/webhooks/b2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth (frontend OAuth)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# NextAuth / session helpers (keep even with Supabase OAuth)
NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# API JWT (use the same value as NEXTAUTH_SECRET locally)
AUTH_JWT_SECRET=generate-a-long-random-string

# =========================
# Production (fill before deploy)
# =========================
# Point DATABASE_URL at Supabase Postgres so briefs/runs/activities land in Supabase:
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Then run infra/supabase-schema.sql in the Supabase SQL editor.
# ADPROOF_DEMO_MODE=false
# PIPELINE_MODE=live
# LOCAL_STORAGE_PATH=
# API_BASE_URL=https://api.your-domain.com
# CORS_ORIGINS=https://your-frontend-domain.com
# NEXT_PUBLIC_API_URL=https://api.your-domain.com
# NEXTAUTH_URL=https://your-frontend-domain.com
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# AUTH_JWT_SECRET=...
# NEXTAUTH_SECRET=...